{
    "id": null,
    "title": "Docker Container Memory Usage",
    "tags": ["docker", "memory"],
    "timezone": "browser",
    "schemaVersion": 38,
    "version": 1,
    "templating": {
      "list": [
        {
          "name": "container",
          "type": "query",
          "label": "Container",
          "datasource": "Prometheus",
          "query": "label_values(docker_container_memory_bytes, container)",
          "multi": true,
          "includeAll": true,
          "allValue": ".*"
        }
      ]
    },
    "panels": [
      {
        "type": "graph",
        "title": "Container Memory Usage (MB)",
        "datasource": "Prometheus",
        "targets": [
          {
            "expr": "docker_container_memory_bytes{container=~\"$container\"} / 1024 / 1024",
            "legendFormat": "{{container}}",
            "refId": "A",
            "format": "time_series",
            "nullValue": "connected",
            "step": "30s"
          }
        ],
        "gridPos": {"x": 0, "y": 0, "w": 24, "h": 8},
        "yaxes": [
          {"unit": "MB", "label": "Memory (MB)", "logBase": 1, "min": 0},
          {"show": false}
        ],
        "seriesOverrides": [],
        "lines": true,
        "linewidth": 2,
        "fill": 1,
        "fillGradient": 0,
        "points": true,
        "pointRadius": 3,
        "pointradius": 3,
        "bars": false,
        "stack": false,
        "percentage": false,
        "steppedLine": false,
        "nullPointMode": "connected",
        "tooltip": {
          "shared": true,
          "sort": 0,
          "value_type": "individual"
        },
        "legend": {
          "show": true,
          "values": true,
          "min": false,
          "max": false,
          "current": true,
          "total": false,
          "avg": true
        }
      }
    ]
  }