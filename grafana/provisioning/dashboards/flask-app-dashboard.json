{
  "id": null,
  "uid": "flask-app-metrics",
  "title": "Flask App Metrics",
  "tags": ["flask", "prometheus", "http"],
  "timezone": "browser",
  "schemaVersion": 38,
  "version": 1,
  "refresh": "10s",
  "templating": {
    "list": [
      {
        "name": "instance",
        "type": "query",
        "label": "Instance",
        "datasource": "Prometheus",
        "query": "label_values(flask_http_request_total, instance)",
        "multi": false,
        "includeAll": false,
        "refresh": 1
      }
    ]
  },
  "panels": [
    {
      "type": "stat",
      "title": "Requests / min",
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "sum(rate(flask_http_request_total{instance=\"$instance\"}[1m])) * 60",
          "refId": "A"
        }
      ],
      "gridPos": {"x": 0, "y": 0, "w": 6, "h": 4},
      "options": {
        "reduceOptions": {
          "values": false,
          "calcs": ["lastNotNull"],
          "fields": ""
        },
        "orientation": "auto",
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "auto"
      }
    },
    {
      "type": "stat",
      "title": "Error Rate %",
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "(sum(rate(flask_http_request_total{instance=\"$instance\",status=~\"5..|4..\"}[5m])) / clamp_min(sum(rate(flask_http_request_total{instance=\"$instance\"}[5m])), 0.0001)) * 100",
          "refId": "A"
        }
      ],
      "gridPos": {"x": 6, "y": 0, "w": 6, "h": 4},
      "options": {
        "reduceOptions": {
          "values": false,
          "calcs": ["lastNotNull"],
          "fields": ""
        },
        "orientation": "auto",
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "decimals": 2
        },
        "overrides": []
      }
    },
    {
      "type": "stat",
      "title": "P95 Latency",
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum by (le) (rate(flask_http_request_duration_seconds_bucket{instance=\"$instance\"}[5m])))",
          "refId": "A"
        }
      ],
      "gridPos": {"x": 12, "y": 0, "w": 6, "h": 4},
      "options": {
        "reduceOptions": {
          "values": false,
          "calcs": ["lastNotNull"],
          "fields": ""
        },
        "orientation": "auto",
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "decimals": 3
        },
        "overrides": []
      }
    },
    {
      "type": "stat",
      "title": "Tracked Paths",
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "count(count by (path) (by_path_counter{instance=\"$instance\"}))",
          "refId": "A"
        }
      ],
      "gridPos": {"x": 18, "y": 0, "w": 6, "h": 4},
      "options": {
        "reduceOptions": {
          "values": false,
          "calcs": ["lastNotNull"],
          "fields": ""
        },
        "orientation": "auto",
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "auto"
      }
    },
    {
      "type": "timeseries",
      "title": "Request Rate by Method and Status",
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "sum by (method, status) (rate(flask_http_request_total{instance=\"$instance\"}[5m]))",
          "legendFormat": "{{method}} {{status}}",
          "refId": "A"
        }
      ],
      "gridPos": {"x": 0, "y": 4, "w": 12, "h": 8},
      "fieldConfig": {
        "defaults": {
          "unit": "reqps"
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom"
        },
        "tooltip": {
          "mode": "multi"
        }
      }
    },
    {
      "type": "timeseries",
      "title": "Latency Quantiles",
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum by (le) (rate(flask_http_request_duration_seconds_bucket{instance=\"$instance\"}[5m])))",
          "legendFormat": "p50",
          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.95, sum by (le) (rate(flask_http_request_duration_seconds_bucket{instance=\"$instance\"}[5m])))",
          "legendFormat": "p95",
          "refId": "B"
        },
        {
          "expr": "histogram_quantile(0.99, sum by (le) (rate(flask_http_request_duration_seconds_bucket{instance=\"$instance\"}[5m])))",
          "legendFormat": "p99",
          "refId": "C"
        }
      ],
      "gridPos": {"x": 12, "y": 4, "w": 12, "h": 8},
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "decimals": 3
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom"
        },
        "tooltip": {
          "mode": "multi"
        }
      }
    },
    {
      "type": "timeseries",
      "title": "Requests by Path",
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "sum by (path) (rate(by_path_counter{instance=\"$instance\"}[5m]))",
          "legendFormat": "{{path}}",
          "refId": "A"
        }
      ],
      "gridPos": {"x": 0, "y": 12, "w": 12, "h": 8},
      "fieldConfig": {
        "defaults": {
          "unit": "reqps"
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom"
        },
        "tooltip": {
          "mode": "multi"
        }
      }
    },
    {
      "type": "table",
      "title": "Status Code Breakdown",
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "sum by (status, method) (increase(flask_http_request_total{instance=\"$instance\"}[15m]))",
          "format": "table",
          "instant": true,
          "refId": "A"
        }
      ],
      "gridPos": {"x": 12, "y": 12, "w": 12, "h": 8},
      "options": {
        "showHeader": true
      }
    }
  ]
}
